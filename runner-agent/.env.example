# Runner Agent — copy to .env and fill in values

# Backend API (internal/private IP of backend VM)
BACKEND_URL=http://BACKEND_PRIVATE_IP:3001

# This worker's identity
NODE_ID=worker-1
NODE_IP=WORKER_PUBLIC_IP        # shown in deployment URLs
NODE_PRIVATE_IP=WORKER_PRIVATE_IP
NODE_PUBLIC_IP=WORKER_PUBLIC_IP
REGION=us-central1
AVAILABILITY_ZONE=us-central1-a

# Concurrency
MAX_CONCURRENT_JOBS=2

# Port range for deployed containers (must match backend PORT_RANGE_START/END)
PORT_RANGE_START=4000
PORT_RANGE_END=5000

# Shared secret — must match WORKER_SECRET in backend .env
WORKER_SECRET=change_this_worker_secret_32chars

# Optional: GitHub token for cloning private repos
# (usually injected per-job from the user's GitHub integration)
GITHUB_TOKEN=
